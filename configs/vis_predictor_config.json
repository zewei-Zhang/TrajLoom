    "aug": {
      "mix_a_max": 0.0,
      "add_sigma": 0.0,
      "token_dropout": 0.0
    },
    "mixed_precision": "bf16"
  },
  "lr_schedule": {
    "schedule": "cosine",
    "warmup_steps": 500,
    "min_lr": 3e-05
  },
  "out_dir": "/path/to/output/vis_predictor/",
  "eval": {
    "ckpt_path": "",
    "batch_size": 4,
    "num_workers": 4,
    "max_batches": 0,
