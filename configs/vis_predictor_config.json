    "hidden": 64,
    "depth": 3,
    "kernel_size": 3,
    "use_hist_last": false,
    "use_delta_to_hist": false
  },
  "train": {
    "batch_size": 4,
    "num_workers": 4,
    "val_fraction": 0.02,
    "lr": 0.0003,
    "weight_decay": 0.01,
    "grad_clip_norm": 1.0,
