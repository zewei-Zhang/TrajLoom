{
  "data": {
    "video_dir": "/path/to/videos/",
    "tracks_dir": "/path/to/data/tracks/",
    "caption_csv": "/path/to/data/captions.csv",
    "caption_video_col": "video_path",
    "caption_text_col": "text",
    "caption_vid_col": "videoid",
    "raw_height": 480,
    "raw_width": 832,
    "hist_len": 81,
    "future_len": 81,
    "use_overlap": false,
    "track_stride": 32,
    "axis_order": "xy",
    "video_reader": "cv2",
    "video_exts": ".mp4",
    "max_frames": 162,
    "train_fraction": 0.9,
    "seed": 42,
    "use_cached_latents": true,
    "cache_dir": "/path/to/data/cache/",
    "cache_manifest_train": "/path/to/data/cache/manifest_train.jsonl",
    "cache_manifest_eval": "/path/to/data/cache/manifest_eval.jsonl",
    "cache_manifest_val": ""
  },
  "video_vae": {
    "enable": true,
    "wan2_repo_dir": "/path/to/Wan2.1/",
    "ckpt_dir": "/path/to/Wan2.1-T2V-1.3B/Wan2.1_VAE.pth",
    "ckpt_name": "Wan2.1_VAE.pth",
    "dtype": "bf16",
    "latents_dir": "",
    "resize_factor": 4
  },
  "text_encoder": {
    "enable": true,
    "wan2_repo_dir": "/path/to/Wan2.1/",
    "ckpt_dir": "/path/to/Wan2.1-T2V-1.3B/",
    "ckpt_name": "models_t5_umt5-xxl-enc-bf16.pth",
    "tokenizer_name": "google/umt5-xxl",
    "max_length": 128,
    "dropout_prob": 0.1,
    "dtype": "bf16"
  },
  "generator": {
    "latent_channels": 16,
    "num_frames_latent": 21,
    "input_height": 480,
    "input_width": 832,
    "patch_size": 32,
    "hidden_size": 768,
    "num_heads": 12,
    "depth": 16,
    "mlp_ratio": 4.0,
    "dropout": 0.0,
    "video_latent_channels": 16,
    "use_video_cond": true,
    "text_embed_dim": 4096,
    "use_text_cond": true,
    "num_frames_in": 81,
    "latent_time_stride": 4,
    "use_overlap": false,
    "temporal_first": true,
    "spatial_ctx_mode": "pooled_last",
    "spatial_ctx_pool": 1,
    "spatial_ctx_last_k": 1,
    "spatial_ctx_include_video": true,
    "video_ctx_mode": "concat",
    "track_fusion": "add_last_plus_vel",
    "track_fusion_scale_init": 0.1,
    "track_fusion_use_time_gate": true,
    "video_fusion": "none",
    "video_fusion_scale_init": 0.05,
    "use_hist_vis_cond": true,
    "hist_vis_scale_init": 1.0
  },
  "train": {
    "resume": null,
    "out_dir": "/path/to/output/track_generator/",
    "batch_size": 32,
    "num_workers": 4,
    "learning_rate": 6e-05,
    "weight_decay": 0.0,
    "num_epochs": 50000,
    "gradient_accumulation_steps": 1,
    "mixed_precision": "bf16",
    "log_every": 10,
    "save_every": 8000,
    "val_every": 200,
    "preview_every": 400,
    "max_val_batches": 1,
    "preview_steps": 10,
    "clip_grad_norm": 1.0,
    "lambda_vis": 0.0,
    "vis_pos_weight": 1.0,
    "latent_stats_json": "/path/to/latent_stats_cache.json",
    "latent_stats_key": "z_all",
    "x0_mode": "anchor_first",
    "x0_noise_std": 0.1,
    "x0_fix_first_latent": false,
    "fm_use_vis_mask": true,
    "fm_invis_weight": 0.01,
    "fm_sigma": 0.05,
    "t_small_prob": 0.2,
    "t_small_max": 0.1,
    "seed": 42,
    "entity": "video-traj",
    "wandb_project": "track_generator",
    "wandb_name": "track-generator-base-b6000-rtx6000-nomaskloss"
  },
  "trajloom_vae": {
    "ckpt_path": "/path/to/checkpoints/trajloom_vae.pt",
    "config": {
      "encoder_depth": 16,
      "decoder_depth": 16,
      "hidden_size": 512,
      "num_heads": 8,
      "patch_size": 32,
      "in_channels": 2,
      "latent_channels": 16,
      "input_height": 480,
      "input_width": 832,
      "num_frames_in": 81,
      "num_frames_latent": 21,
      "use_temp_compress": true,
      "temp_stride": 4,
      "use_offsets": true,
      "num_frame_tokens": 256,
      "learn_sigma": false,
      "beta": 5e-05,
      "pos_embed_dim": 64
    }
  }
}
